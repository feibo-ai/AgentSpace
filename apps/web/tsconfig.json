{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "es2022"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "allowImportingTsExtensions": true,
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@agent-space/domain": [
        "../../packages/domain/src/index.ts"
      ],
      "@agent-space/domain/*": [
        "../../packages/domain/src/*.ts"
      ],
      "@agent-space/services": [
        "../../packages/services/src/index.ts"
      ],
      "@agent-space/services/*": [
        "../../packages/services/src/*.ts"
      ],
      "@agent-space/db": [
        "../../packages/db/src/index.ts"
      ],
      "@agent-space/db/*": [
        "../../packages/db/src/*.ts"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "**/*.test.ts",
    "**/*.test.tsx",
    "test/**",
    "e2e/**"
  ]
}
