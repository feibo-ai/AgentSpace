{
  "extends": "./tsconfig.typecheck.json",
  "compilerOptions": {
    "incremental": false,
    "types": [
      "vitest/globals",
      "@testing-library/jest-dom",
      "node"
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.test.ts",
    "**/*.test.tsx",
    "test/**/*.ts",
    "test/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "e2e/**"
  ]
}
