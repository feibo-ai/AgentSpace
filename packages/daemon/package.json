{
  "name": "agent-space-daemon",
  "version": "0.1.3",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "agent-router": "./bin/agent-router.js",
    "agent-space": "./bin/agent-space.js",
    "agent-space-daemon": "./bin/agent-space-daemon.js"
  },
  "exports": {
    ".": {
      "types": "./dist-types/index.d.ts",
      "default": "./dist/index.js"
    },
    "./daemon-client": {
      "types": "./dist-types/daemon-client.d.ts",
      "default": "./dist/daemon-client.js"
    },
    "./agent-router": {
      "types": "./dist-types/agent-router/index.d.ts",
      "default": "./dist/agent-router/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "bin",
    "dist",
    "dist-types",
    "README.md",
    "package.json"
  ],
  "engines": {
    "node": ">=20.20.0"
  },
  "scripts": {
    "pretypes": "npm --prefix ../domain run types && npm --prefix ../db run types && npm --prefix ../services run types && ../../apps/web/node_modules/.bin/tsc -p ../sandbox/tsconfig.types.json --incremental false",
    "types": "../../apps/web/node_modules/.bin/tsc -p tsconfig.types.json --incremental false",
    "build": "node ./scripts/build.mjs",
    "prepack": "npm run types && npm run build",
    "agent-space-daemon": "node ./bin/agent-space-daemon.js"
  },
  "dependencies": {
    "@agent-space/db": "file:../db",
    "@agent-space/domain": "file:../domain",
    "@agent-space/sandbox": "file:../sandbox",
    "@agent-space/services": "file:../services"
  },
  "devDependencies": {
    "esbuild": "^0.27.7"
  }
}
