{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "declaration": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "types": [
      "node"
    ],
    "typeRoots": [
      "../../apps/web/node_modules/@types"
    ],
    "rootDir": "./src",
    "outDir": "./dist-types",
    "paths": {
      "@agent-space/domain": [
        "../domain/dist-types/index.d.ts"
      ],
      "@agent-space/domain/*": [
        "../domain/dist-types/*"
      ],
      "@agent-space/db": [
        "../db/dist-types/index.d.ts"
      ]
    }
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/**/*.test.ts"
  ]
}
